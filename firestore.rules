rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Context States collection - FIXED permissions for guest and authenticated users
    match /contextStates/{contextId} {
  allow read: if
  (request.auth == null && resource.data.userId == 'guest') ||
  (request.auth != null && resource.data.userId == request.auth.uid);
  allow create: if 
    (request.auth == null && request.resource.data.userId == 'guest') ||
    (request.auth != null && request.auth.uid == request.resource.data.userId);

  allow update, delete: if 
    (request.auth == null && resource != null && resource.data.userId == 'guest') ||
    (request.auth != null && resource != null && resource.data.userId == request.auth.uid);
}

    
    // Conversations collection - users can only access conversations they participate in
    match /conversations/{conversationId} {
      allow read, write: if 
        // Authenticated users in participantIds
        (request.auth != null && request.auth.uid in resource.data.participantIds) ||
        // Guest users can access conversations with 'guest' in participantIds
        (request.auth == null && 'guest' in resource.data.participantIds);
      
      allow create: if 
        // Authenticated users creating conversations
        (request.auth != null && request.auth.uid in request.resource.data.participantIds) ||
        // Guest users creating conversations
        (request.auth == null && 'guest' in request.resource.data.participantIds);
        
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if 
          // Authenticated users in conversation participantIds
          (request.auth != null && 
           request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds) ||
          // Guest users in conversation with 'guest' in participantIds
          (request.auth == null && 
           'guest' in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds);
        
        allow create: if 
          // Authenticated users creating messages
          (request.auth != null && 
           request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds) ||
          // Guest users creating messages
          (request.auth == null && 
           'guest' in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds);
      }
    }
    
    // Guest sessions - allow anonymous access for guest users
    match /guestSessions/{sessionId} {
      allow read, write: if true;
    }
  }
}